      "Bash(curl -s \"https://raw.githubusercontent.com/qbwc/qbxml/master/schema/qbxmlops140.xml\")",
      "Bash(curl -sI \"https://raw.githubusercontent.com/qbwc/qbxml/master/schema/qbxmlops140.xml\")",
      "PowerShell(npm run build)",
      "PowerShell(npm test 2>&1)",
      "PowerShell(\"\" | & node dist/index.js 2>&1 | Select-Object -First 10; \"exit=$LASTEXITCODE\")",
      "PowerShell(npx vitest run tests/invoice-duplicate.test.ts 2>&1)",
      "PowerShell(npm run build; npm test 2>&1 | Select-String -Pattern \"Test Files|Tests \" | Select-Object -Last 2; \"\" | & node dist/index.js 2>&1 | Select-String -Pattern \"Mode:|stdio\"; \"exit=$LASTEXITCODE\")",
