# QuickBooks Desktop MCP — environment variables
# Copy to .env (gitignored) and fill in for live mode. Defaults are simulation-friendly.

# ---------------------------------------------------------------------------
# Mode selection
# ---------------------------------------------------------------------------
# QB_SIMULATION is the explicit override:
#   "true"  — force simulation (any platform, any QB_LIVE value)
#   "false" — force live; openSession will error if the platform can't do live
#   unset   — default behavior: simulate unless on Windows with QB_LIVE="1"
# Any other value is treated as unset.
#QB_SIMULATION=true

# QB_LIVE is honored only when QB_SIMULATION is unset.
# Set to "1" on Windows to opt into live mode. Any other value (or unset) keeps
# the default-to-simulation behavior on Windows.
#QB_LIVE=1

# ---------------------------------------------------------------------------
# Connection details (live mode)
# ---------------------------------------------------------------------------
# Path to the QuickBooks .qbw company file. Required for live mode.
#QB_COMPANY_FILE=C:\Users\Public\Documents\Intuit\QuickBooks\Sample Company.qbw

# Search root for qb_company_list (Item 35). When set, qb_company_list scans
# this directory for .qbw files and returns them sorted by modifiedAt desc;
# the returned paths are valid input to qb_company_open. When unset, the tool
# falls back to dirname($QB_COMPANY_FILE).
#QB_COMPANY_ROOT=C:\Users\Public\Documents\Intuit\QuickBooks

# Application identity registered with QuickBooks.
#QB_APP_NAME=MCP QuickBooks Manager
#QB_APP_ID=

# QBXML protocol version to negotiate. Most modern QB Desktop builds support 16.0.
#QB_QBXML_VERSION=16.0

# Connection mode for QBXMLRP2:
#   localOnly   — only connect when QB Desktop is open
#   remoteOnly  — only connect when QB Desktop is closed (background)
#   optimistic  — try local first, fall back to remote
#QB_CONNECTION_MODE=optimistic
